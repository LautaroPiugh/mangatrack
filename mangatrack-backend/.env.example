# App
APP_NAME=MangaTrack
NODE_ENV=development
PORT=5000
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/mangatrack

# JWT
JWT_SECRET=change_this_for_a_long_random_secret
JWT_EXPIRES_IN=1d
JWT_ISSUER=MangaTrack API
JWT_AUDIENCE=MangaTrack Client

# Admin seed
ADMIN_NAME=
ADMIN_USERNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Email
# Desarrollo local: imprime el correo en consola y no usa SMTP real.
EMAIL_MODE=json
EMAIL_FROM=MangaTrack <no-reply@mangatrack.local>
FRONTEND_URL=http://localhost:5173

# SMTP real: descomenta y completa estos valores para enviar emails reales.
# Si usas Gmail, no uses tu contrasena normal: crea un App Password.
# EMAIL_MODE=smtp
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=tu_email@gmail.com
# EMAIL_PASS=tu_app_password
# EMAIL_FROM=MangaTrack <tu_email@gmail.com>
# FRONTEND_URL=http://localhost:5173
